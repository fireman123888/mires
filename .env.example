# Copy to .env (local) or set as Vercel env vars (production).

# ---- Database (PostgreSQL, e.g. Neon) ----
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ---- Image generation: Pollinations.AI (free, key-less) ----
# Powers the "nano-banana-2" model entry. Keep `flux` unless you know better.
POLLINATIONS_FLUX_MODEL=flux

# ---- Internal request signing key ----
# Any random hex string. Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# NEXT_PUBLIC_* is exposed to the browser — this is light obfuscation, not security.
NEXT_PUBLIC_API_KEY=change-me-to-a-random-hex-string

# ---- App ----
NEXT_PUBLIC_BASE_URL=https://your-domain.example
NEXT_PUBLIC_WEB_VERSION=1.0.0
COMMUNITY_IMAGES_PUBLIC=false
NSFW_REPORT_THRESHOLD=3

# ---- Optional: LLM prompt optimization (Chinese -> English) ----
# Any OpenAI-compatible endpoint. Examples:
#   Gemini:        https://generativelanguage.googleapis.com/v1beta/openai
#   SiliconFlow:   https://api.siliconflow.cn/v1
#   DeepSeek:      https://api.deepseek.com/v1
PROMPT_OPTIMIZATION_BASE_URL=
PROMPT_OPTIMIZATION_API_KEY=
PROMPT_OPTIMIZATION_MODEL=gemini-2.5-flash-lite
PROMPT_OPTIMIZATION_MAX_TOKENS=2000

# ---- Optional: ComfyUI model endpoints (only if self-hosting ComfyUI) ----
# HiDream_Fp8_URL=
# Flux_Dev_URL=
# Flux_Krea_URL=
# Stable_Diffusion_3_5_URL=
# Qwen_Image_URL=
# Qwen_Image_Edit_URL=
# Kontext_fp8_URL=
# Wai_SDXL_V150_URL=
# Z_IMAGE_URL=
# Z_Image_Turbo_URL=
# Flux_2_URL=

# ---- Optional: Other image backends ----
# REPLICATE_API_TOKEN=
# GROK_IMAGINE_API_URL=
# GROK_IMAGINE_API_KEY=

# ---- Optional: OSS for community uploads ----
# OSS_AK=
# OSS_SK=
# OSS_BUCKET=
# OSS_ENDPOINT=

# ---- Optional: Avatar moderation ----
# AVATAR_MODERATION_BASE_URL=
# AVATAR_MODERATION_API_KEY=
# AVATAR_MODERATION_MODEL=

# ---- Optional: Email auth (Resend) ----
# RESEND_API_KEY=
